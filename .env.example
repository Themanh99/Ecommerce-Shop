# MoonKid local development defaults.
# Copy to .env and change every secret before using compose.prod.yml.

COMPOSE_PROJECT_NAME=moonkid
APP_URL=http://localhost:8088
HTTP_PORT=8088
FRONTEND_PORT=3000
BACKEND_PORT=8080

POSTGRES_USER=moonkid
POSTGRES_PASSWORD=moonkid_dev_password
POSTGRES_DB=moonkid
POSTGRES_PORT=5432

REDIS_PASSWORD=moonkid_redis_dev
REDIS_PORT=6379
REDIS_MAXMEMORY=512mb

MINIO_ROOT_USER=moonkid
MINIO_ROOT_PASSWORD=moonkid_minio_dev
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025
MAIL_FROM="MoonKid <no-reply@moonkid.local>"

JWT_ACCESS_SECRET=local_access_secret_change_before_deploy_0123456789
JWT_REFRESH_SECRET=local_refresh_secret_change_before_deploy_0123456789
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8088/api/auth/google/callback

SEED_ADMIN_EMAIL=admin@moonkid.local
SEED_ADMIN_PASSWORD=MoonKid@123
SEED_CUSTOMER_EMAIL=customer@moonkid.local
SEED_CUSTOMER_PASSWORD=MoonKid@123

# Production-only SMTP values
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=

# Optional immutable image references for production deployment
BACKEND_IMAGE=moonkid-backend:local
FRONTEND_IMAGE=moonkid-frontend:local
